<div
    class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr
                    class="bg-slate-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    <th class="py-4 px-4 w-10">
                    </th>
                    <th data-sortable="true" data-column="id"
                        data-sort-dir="<%= typeof sortBy !== 'undefined' && sortBy === 'id' ? sortDir : '' %>"
                        class="py-4 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                        ID
                        <i
                            class="fas fa-sort<%= typeof sortBy !== 'undefined' && sortBy === 'id' ? (sortDir === 'asc' ? '-up' : '-down') : '' %> ml-1"></i>
                    </th>
                    <th data-sortable="true" data-column="borrower_name"
                        data-sort-dir="<%= typeof sortBy !== 'undefined' && sortBy === 'borrower_name' ? sortDir : '' %>"
                        class="py-4 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                        Borrower
                        <i
                            class="fas fa-sort<%= typeof sortBy !== 'undefined' && sortBy === 'borrower_name' ? (sortDir === 'asc' ? '-up' : '-down') : '' %> ml-1"></i>
                    </th>
                    <th data-sortable="true" data-column="amount"
                        data-sort-dir="<%= typeof sortBy !== 'undefined' && sortBy === 'amount' ? sortDir : '' %>"
                        class="py-4 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                        Amount
                        <i
                            class="fas fa-sort<%= typeof sortBy !== 'undefined' && sortBy === 'amount' ? (sortDir === 'asc' ? '-up' : '-down') : '' %> ml-1"></i>
                    </th>
                    <th data-sortable="true" data-column="emi"
                        data-sort-dir="<%= typeof sortBy !== 'undefined' && sortBy === 'emi' ? sortDir : '' %>"
                        class="py-4 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                        EMI
                        <i
                            class="fas fa-sort<%= typeof sortBy !== 'undefined' && sortBy === 'emi' ? (sortDir === 'asc' ? '-up' : '-down') : '' %> ml-1"></i>
                    </th>
                    <th class="py-4 px-4">
                        Progress
                        (Paid/Total)</th>
                    <th class="py-4 px-4">
                        Next Due</th>
                    <th data-sortable="true" data-column="status"
                        data-sort-dir="<%= typeof sortBy !== 'undefined' && sortBy === 'status' ? sortDir : '' %>"
                        class="py-4 px-4 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                        Status
                        <i
                            class="fas fa-sort<%= typeof sortBy !== 'undefined' && sortBy === 'status' ? (sortDir === 'asc' ? '-up' : '-down') : '' %> ml-1"></i>
                    </th>
                    <th class="py-4 px-4">
                        Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                <% if (loans.length===0) { %>
                    <tr>
                        <td colspan="9" class="py-16 px-6 text-center">
                            <div class="flex flex-col items-center justify-center space-y-4">
                                <div
                                    class="w-20 h-20 bg-primary/5 dark:bg-primary/10 rounded-full flex items-center justify-center mb-2">
                                    <i class="fas fa-hand-holding-usd text-4xl text-primary/80"></i>
                                </div>
                                <h3 class="text-lg font-bold text-slate-800 dark:text-white">
                                    No
                                    active
                                    loans
                                    found
                                </h3>
                                <p class="text-sm text-slate-500 max-w-sm mx-auto leading-relaxed">
                                    No loans
                                    match
                                    your
                                    criteria
                                    or there
                                    are no
                                    active
                                    loans in
                                    the
                                    system.
                                    Disburse
                                    a new
                                    loan to
                                    get
                                    started.
                                </p>
                                <% if (locals.user && locals.user.role !=='member' ) { %>
                                    <button onclick="document.getElementById('loan-modal').classList.remove('hidden')"
                                        class="btn-primary mt-4 shadow-lg shadow-primary/20 hover:-translate-y-0.5 transition-all">
                                        <i class="fas fa-plus mr-2"></i>
                                        Disburse
                                        Loan
                                    </button>
                                    <% } %>
                            </div>
                        </td>
                    </tr>
                    <% } else { %>
                        <% loans.forEach(function(l, index) { %>
                            <!-- Main Row -->
                            <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-700/30 transition-colors cursor-pointer group"
                                onclick="toggleLoanDetails(<%= index %>)">
                                <td class="py-4 px-4 text-center">
                                    <i class="fas fa-chevron-right text-slate-400 group-hover:text-primary transition-transform duration-200"
                                        id="icon-<%= index %>"></i>
                                </td>
                                <td class="py-4 px-4 font-mono text-sm text-slate-500">
                                    #<%= l.id %>
                                </td>
                                <td class="py-4 px-4">
                                    <div class="font-medium text-slate-800 dark:text-slate-200">
                                        <%= l.borrower_name %>
                                    </div>
                                    <div class="text-xs text-slate-500">
                                        <%= l.borrower_type %>
                                    </div>
                                </td>
                                <td class="py-4 px-4 font-bold text-slate-800 dark:text-slate-200">
                                    <%= formatCurrency(l.amount) %>
                                </td>
                                <td class="py-4 px-4 font-mono text-slate-600">
                                    <%= formatCurrency(l.emi) %>
                                </td>
                                <td class="py-4 px-4 min-w-[140px]">
                                    <div class="flex items-center gap-2 text-sm mb-1">
                                        <span class="font-bold text-primary">
                                            <%= l.emisPaid %>
                                        </span>
                                        <span class="text-slate-400">/</span>
                                        <span class="text-slate-600">
                                            <%= l.totalEMIs %>
                                        </span>
                                    </div>
                                    <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                        <div class="bg-primary h-1.5 rounded-full transition-all duration-500"
                                            style="width: <%= (l.emisPaid / l.totalEMIs * 100).toFixed(1) %>%; max-width: 100%">
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 px-4">
                                    <% if(l.nextDueMonth) { %>
                                        <span
                                            class="text-warning-dark font-medium text-sm bg-warning/10 px-2 py-1 rounded">
                                            <%= l.nextDueMonth %>
                                        </span>
                                        <% } else { %>
                                            <span class="text-slate-400">-</span>
                                            <% } %>
                                </td>
                                <td class="py-4 px-4">
                                    <span class="badge <%= l.status === 'active' ? 'success' : 'secondary' %>">
                                        <%= l.status %>
                                    </span>
                                </td>
                                <td class="py-4 px-4" onclick="event.stopPropagation();">
                                    <div class="flex items-center gap-2">
                                        <% if(l.status==='active' && locals.user && locals.user.role !=='member' ) { %>
                                            <button class="btn-primary py-1.5 px-3 text-xs"
                                                onclick="openRepayModal('<%= l.id %>', '<%= l.emi %>', '<%= l.nextDueMonth %>', '<%= l.outstanding || 0 %>')">
                                                Pay
                                            </button>
                                            <% if (locals.user && locals.user.role==='admin' ) { %>
                                                <button
                                                    class="btn-secondary py-1.5 px-3 text-xs text-primary bg-primary/10 border-none hover:bg-primary/20"
                                                    onclick="openWaiveModal('<%= l.id %>', '<%= Math.max(0, l.totalInterest - l.interestCollected) %>', '<%= l.outstanding %>')">
                                                    Waive
                                                </button>
                                                <% } %>
                                                    <% } %>

                                                        <% if(locals.user && locals.user.role==='admin' ) { %>
                                                            <button type="button"
                                                                class="btn-icon btn-ghost text-slate-400 hover:text-danger"
                                                                onclick="openDeleteModal('<%= l.id %>')">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                            <% } %>
                                    </div>
                                </td>
                            </tr>

                            <!-- Expandable Details Row -->
                            <tr id="details-<%= index %>" class="hidden bg-slate-50/50 dark:bg-slate-800/50">
                                <td colspan="9" class="p-0 border-b border-slate-100 dark:border-slate-700">
                                    <div class="p-6 pl-14 border-l-4 border-primary">
                                        <h3 class="text-base font-bold text-primary mb-4 flex items-center gap-2">
                                            <i class="fas fa-info-circle"></i>
                                            Loan
                                            Details
                                        </h3>

                                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                            <!-- Loan Information -->
                                            <div
                                                class="bg-white dark:bg-slate-800 p-4 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700">
                                                <h4
                                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">
                                                    <i class="fas fa-file-invoice-dollar mr-1"></i>
                                                    Loan
                                                    Information
                                                </h4>
                                                <div class="space-y-2 text-sm">
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Principal
                                                            Amount:</span>
                                                        <span class="font-bold text-slate-700 dark:text-slate-200">
                                                            <%= formatCurrency(l.amount) %>
                                                        </span>
                                                    </div>
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Interest
                                                            Rate:</span>
                                                        <span class="font-bold text-slate-700 dark:text-slate-200">
                                                            <%= l.interest_rate %>
                                                                %
                                                                /
                                                                mo
                                                        </span>
                                                    </div>
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Tenure:</span>
                                                        <span class="font-bold text-slate-700 dark:text-slate-200">
                                                            <%= l.tenure %>
                                                                months
                                                        </span>
                                                    </div>
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Start
                                                            Date:</span>
                                                        <span class="font-bold text-slate-700 dark:text-slate-200">
                                                            <%= new Date(l.start_date).toLocaleDateString() %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Interest Breakdown -->
                                            <div
                                                class="bg-white dark:bg-slate-800 p-4 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700">
                                                <h4
                                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">
                                                    <i class="fas fa-percentage mr-1"></i>
                                                    Interest
                                                    Breakdown
                                                </h4>
                                                <div class="space-y-2 text-sm">
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Total
                                                            Interest:</span>
                                                        <span class="font-bold text-warning-dark">
                                                            <%= formatCurrency(l.totalInterest) %>
                                                        </span>
                                                    </div>
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Interest
                                                            Paid:</span>
                                                        <span class="font-bold text-success">
                                                            <%= formatCurrency(l.interestCollected) %>
                                                        </span>
                                                    </div>
                                                    <% if (l.interest_waived> 0) { %>
                                                        <div class="flex justify-between">
                                                            <span class="text-slate-500">Waived:</span>
                                                            <span class="font-bold text-sky-500">
                                                                <%= formatCurrency(l.interest_waived) %>
                                                            </span>
                                                        </div>
                                                        <% } %>
                                                            <div class="flex justify-between">
                                                                <span class="text-slate-500">Pending
                                                                    Interest:</span>
                                                                <span class="font-bold text-danger">
                                                                    <%= formatCurrency(l.pendingInterest) %>
                                                                </span>
                                                            </div>
                                                            <div
                                                                class="pt-2 mt-2 border-t border-slate-100 flex justify-between">
                                                                <span class="text-slate-600 font-medium">Total
                                                                    Payable:</span>
                                                                <span class="font-bold text-primary">
                                                                    <%= formatCurrency(l.totalPayable) %>
                                                                </span>
                                                            </div>
                                                </div>
                                            </div>

                                            <!-- Payment Summary -->
                                            <div
                                                class="bg-white dark:bg-slate-800 p-4 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700">
                                                <h4
                                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">
                                                    <i class="fas fa-chart-line mr-1"></i>
                                                    Payment
                                                    Summary
                                                </h4>
                                                <div class="space-y-2 text-sm">
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Amount
                                                            Repaid:</span>
                                                        <span class="font-bold text-success">
                                                            <%= formatCurrency(l.amountRepaid) %>
                                                        </span>
                                                    </div>
                                                    <div class="flex justify-between">
                                                        <span class="text-slate-500">Outstanding
                                                            Balance:</span>
                                                        <span class="font-bold text-danger">
                                                            <%= formatCurrency(l.outstanding) %>
                                                        </span>
                                                    </div>

                                                    <div class="pt-2 mt-1">
                                                        <div class="flex justify-between text-xs mb-1">
                                                            <span class="text-slate-500">Repayment
                                                                Progress</span>
                                                            <span class="font-bold text-slate-700 dark:text-slate-200">
                                                                <%= ((l.amountRepaid / l.totalPayable) * 100).toFixed(1)
                                                                    %>
                                                                    %
                                                            </span>
                                                        </div>
                                                        <div
                                                            class="w-full bg-slate-100 rounded-full h-2 overflow-hidden">
                                                            <div class="bg-gradient-to-r from-success to-primary h-2 rounded-full transition-all duration-500"
                                                                style="width: <%= ((l.amountRepaid / l.totalPayable) * 100).toFixed(1) %>%; max-width: 100%">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <% if(l.status==='active' ) { %>
                                            <div
                                                class="mt-4 p-3 bg-amber-50 border-l-4 border-amber-400 rounded-r flex items-center gap-3">
                                                <i class="fas fa-calendar-alt text-amber-500"></i>
                                                <div class="text-sm text-amber-900">
                                                    <strong>Next
                                                        Payment
                                                        Due:</strong>
                                                    <span class="mx-1 font-medium">
                                                        <%= l.nextDueMonth %>
                                                    </span>
                                                    -
                                                    <span class="font-bold ml-1">
                                                        <%= formatCurrency(l.emi) %>
                                                    </span>
                                                </div>
                                            </div>
                                            <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <% if(typeof pagination !=='undefined' && pagination.totalPages> 1) { %>
        <div
            class="px-6 py-4 flex items-center justify-between border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
            <div class="flex-1 flex justify-between sm:hidden">
                <a href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage - 1 %>&<%= typeof search !== 'undefined' ? 'search=' + search : '' %>&<%= typeof statusFilter !== 'undefined' ? 'status=' + statusFilter : '' %>&<%= typeof sortBy !== 'undefined' ? 'sortBy=' + sortBy : '' %>&<%= typeof sortDir !== 'undefined' ? 'sortDir=' + sortDir : '' %>"
                    class="btn-secondary <%= pagination.currentPage <= 1 ? 'pointer-events-none opacity-50' : '' %>">Previous</a>
                <a href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage + 1 %>&<%= typeof search !== 'undefined' ? 'search=' + search : '' %>&<%= typeof statusFilter !== 'undefined' ? 'status=' + statusFilter : '' %>&<%= typeof sortBy !== 'undefined' ? 'sortBy=' + sortBy : '' %>&<%= typeof sortDir !== 'undefined' ? 'sortDir=' + sortDir : '' %>"
                    class="btn-secondary <%= pagination.currentPage >= pagination.totalPages ? 'pointer-events-none opacity-50' : '' %>">Next</a>
            </div>
            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm text-slate-700 dark:text-slate-300">
                        Showing page <span class="font-medium">
                            <%= pagination.currentPage %>
                        </span> of <span class="font-medium">
                            <%= pagination.totalPages %>
                        </span>
                    </p>
                </div>
                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <a href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage - 1 %>&<%= typeof search !== 'undefined' ? 'search=' + search : '' %>&<%= typeof statusFilter !== 'undefined' ? 'status=' + statusFilter : '' %>&<%= typeof sortBy !== 'undefined' ? 'sortBy=' + sortBy : '' %>&<%= typeof sortDir !== 'undefined' ? 'sortDir=' + sortDir : '' %>"
                        class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm font-medium text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 <%= pagination.currentPage <= 1 ? 'pointer-events-none opacity-50' : '' %>">
                        <span class="sr-only">Previous</span>
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    <% for(let i=1; i <=pagination.totalPages; i++) { %>
                        <a href="<%= pagination.baseUrl %>?page=<%= i %>&<%= typeof search !== 'undefined' ? 'search=' + search : '' %>&<%= typeof statusFilter !== 'undefined' ? 'status=' + statusFilter : '' %>&<%= typeof sortBy !== 'undefined' ? 'sortBy=' + sortBy : '' %>&<%= typeof sortDir !== 'undefined' ? 'sortDir=' + sortDir : '' %>"
                            class="relative inline-flex items-center px-4 py-2 border text-sm font-medium transition-colors <%= pagination.currentPage === i ? 'z-10 bg-primary/10 border-primary text-primary dark:bg-primary/20 dark:text-primary-light' : 'bg-white dark:bg-slate-800 border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                            <%= i %>
                        </a>
                        <% } %>

                            <a href="<%= pagination.baseUrl %>?page=<%= pagination.currentPage + 1 %>&<%= typeof search !== 'undefined' ? 'search=' + search : '' %>&<%= typeof statusFilter !== 'undefined' ? 'status=' + statusFilter : '' %>&<%= typeof sortBy !== 'undefined' ? 'sortBy=' + sortBy : '' %>&<%= typeof sortDir !== 'undefined' ? 'sortDir=' + sortDir : '' %>"
                                class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm font-medium text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 <%= pagination.currentPage >= pagination.totalPages ? 'pointer-events-none opacity-50' : '' %>">
                                <span class="sr-only">Next</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                </nav>
            </div>
        </div>
        <% } %>