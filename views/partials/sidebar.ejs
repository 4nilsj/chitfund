<script src="/js/theme.js"></script>
<aside
    class="fixed inset-y-0 left-0 w-64 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 transform transition-transform duration-300 ease-in-out z-30 flex flex-col"
    id="sidebar">
    <div class="h-16 flex items-center px-6 border-b border-slate-100 dark:border-slate-800">
        <div
            class="text-xl font-bold bg-gradient-to-r from-primary to-primary-dark bg-clip-text text-transparent flex items-center gap-2">
            <i class="fas fa-coins text-primary"></i>
            <%= locals.fundName || 'Chit Fund' %>
        </div>
    </div>

    <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
        <a href="/"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'dashboard' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-home w-5 text-center"></i> Dashboard
        </a>
        <a href="/members?type=member"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'members' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-users w-5 text-center"></i> Members
        </a>
        <a href="/members?type=public"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'public' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-user-friends w-5 text-center"></i> Public
        </a>
        <a href="/loans"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'loans' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-hand-holding-usd w-5 text-center"></i> Loans
        </a>
        <a href="/transactions"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'transactions' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-exchange-alt w-5 text-center"></i> Transactions
        </a>
        <a href="/reports"
            class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'reports' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
            <i class="fas fa-chart-line w-5 text-center"></i> Reports
        </a>
        <% if(locals.user && locals.user.role==='admin' ) { %>
            <div class="pt-4 mt-4 border-t border-slate-100 dark:border-slate-800">
                <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Admin</p>
                <a href="/settings"
                    class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'settings' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
                    <i class="fas fa-cog w-5 text-center"></i> Settings
                </a>
                <a href="/users"
                    class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= locals.activePage === 'users' ? 'bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-slate-200' %>">
                    <i class="fas fa-users-cog w-5 text-center"></i> Users
                </a>
            </div>
            <% } %>
    </nav>

    <% if(locals.user) { %>
        <!-- User Profile Card -->
        <div class="p-4 border-t border-slate-100 dark:border-slate-800">
            <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between px-3 py-2 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-700/50 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700/50 transition-colors"
                    onclick="toggleTheme()" title="Toggle Theme">
                    <div class="flex items-center gap-3">
                        <i id="theme-toggle-icon" class="fas fa-moon text-slate-500 dark:text-yellow-400 text-lg"></i>
                        <span id="theme-toggle-text" class="text-sm font-medium text-slate-600 dark:text-slate-300">Dark
                            Mode</span>
                    </div>
                </div>

                <div
                    class="flex items-center gap-3 p-3 bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-100 dark:border-slate-700">
                    <div
                        class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-primary-light flex items-center justify-center text-white font-bold text-lg shadow-sm">
                        <%= locals.user.username.charAt(0).toUpperCase() %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="font-semibold text-slate-800 dark:text-slate-200 text-sm truncate">
                            <%= locals.user.username %>
                        </div>
                        <div class="text-xs text-slate-500 dark:text-slate-400 capitalize">
                            <%= locals.user.role %>
                        </div>
                    </div>
                    <a href="/logout"
                        class="p-2 text-slate-400 dark:text-slate-500 hover:text-danger dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                        title="Logout">
                        <i class="fas fa-sign-out-alt"></i>
                    </a>
                </div>
            </div>
            <% } %>
</aside>

<style>
    /* Sidebar Toggle Styles */
    .sidebar-toggle {
        position: fixed;
        left: 240px;
        top: 20px;
        z-index: 50;
        width: 32px;
        height: 32px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    /* Dark mode toggle styles */
    :root.dark .sidebar-toggle {
        background: #0f172a;
        border-color: #1e293b;
        color: #94a3b8;
    }

    :root.dark .sidebar-toggle:hover {
        color: #818cf8;
        border-color: #6366f1;
    }

    .sidebar-toggle:hover {
        color: #4f46e5;
        border-color: #6366f1;
        transform: scale(1.05);
    }

    /* Collapsed States */
    #sidebar.collapsed {
        transform: translateX(-100%);
    }

    .sidebar-toggle.collapsed {
        left: 20px;
    }

    /* Main Content Transitions */
    .main-content {
        transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        width: 100%;
    }

    .main-content.expanded {
        margin-left: 0 !important;
    }

    @media (max-width: 768px) {
        .sidebar-toggle {
            left: auto;
            right: 20px;
        }

        .sidebar-toggle.collapsed {
            left: auto;
            right: 20px;
        }

        #sidebar {
            transform: translateX(-100%);
        }

        #sidebar.active {
            transform: translateX(0);
        }
    }
</style>

<!-- Sidebar Toggle Button -->
<button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()" title="Toggle Sidebar">
    <i class="fas fa-bars" id="toggle-icon"></i>
</button>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('sidebar-toggle');
        const toggleIcon = document.getElementById('toggle-icon');
        const mainContent = document.querySelector('.main-content');

        sidebar.classList.toggle('collapsed');
        toggleBtn.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');

        // Change icon
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.className = 'fas fa-chevron-right';
            localStorage.setItem('sidebarCollapsed', 'true');
        } else {
            toggleIcon.className = 'fas fa-bars';
            localStorage.setItem('sidebarCollapsed', 'false');
        }
    }

    // Restore sidebar state from localStorage
    document.addEventListener('DOMContentLoaded', function () {
        const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        if (isCollapsed) {
            toggleSidebar();
        }
    });
</script>