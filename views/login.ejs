<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
        <title>Login - <%= fundName %>
        </title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
            rel="stylesheet">
        <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #0f172a;
            }

            @keyframes blob {
                0% {
                    transform: translate(0px, 0px) scale(1);
                }

                33% {
                    transform: translate(30px, -50px) scale(1.1);
                }

                66% {
                    transform: translate(-20px, 20px) scale(0.9);
                }

                100% {
                    transform: translate(0px, 0px) scale(1);
                }
            }

            .animate-blob {
                animation: blob 7s infinite;
            }

            .animation-delay-2000 {
                animation-delay: 2s;
            }

            .animation-delay-4000 {
                animation-delay: 4s;
            }

            @keyframes shake {

                0%,
                100% {
                    transform: translateX(0);
                }

                10%,
                30%,
                50%,
                70%,
                90% {
                    transform: translateX(-4px);
                }

                20%,
                40%,
                60%,
                80% {
                    transform: translateX(4px);
                }
            }

            .animate-shake {
                animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
            }

            @keyframes shimmer {
                100% {
                    transform: translateX(100%);
                }
            }
        </style>
</head>

<body
    class="flex items-center justify-center min-h-screen relative overflow-hidden text-slate-200 selection:bg-sky-500/30">

    <!-- Ambient glowing backgrounds -->
    <div
        class="absolute top-[-10%] left-[-10%] w-[30rem] h-[30rem] bg-sky-500/30 rounded-full mix-blend-screen filter blur-[120px] opacity-60 animate-blob pointer-events-none">
    </div>
    <div
        class="absolute top-[20%] right-[-10%] w-[25rem] h-[25rem] bg-indigo-500/30 rounded-full mix-blend-screen filter blur-[100px] opacity-60 animate-blob animation-delay-2000 pointer-events-none">
    </div>
    <div
        class="absolute bottom-[-20%] left-[20%] w-[35rem] h-[35rem] bg-purple-500/20 rounded-full mix-blend-screen filter blur-[120px] opacity-60 animate-blob animation-delay-4000 pointer-events-none">
    </div>

    <div class="relative z-10 w-full max-w-[480px] px-6">
        <!-- Login Card -->
        <div
            class="bg-slate-900/60 backdrop-blur-2xl border border-white/10 rounded-[2.5rem] shadow-2xl p-10 sm:p-12 relative overflow-hidden transition-all duration-300 hover:shadow-sky-500/5 hover:border-white/20 group">

            <!-- decorative top gradient border -->
            <div
                class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-sky-400 via-indigo-500 to-purple-500 opacity-80">
            </div>

            <div class="text-center mb-10 mt-2">
                <div
                    class="mx-auto w-16 h-16 rounded-2xl bg-white/5 border border-white/10 mb-6 shadow-inner flex items-center justify-center group-hover:scale-110 transition-transform duration-500 ease-out">
                    <i
                        class="fas fa-layer-group text-3xl text-transparent bg-clip-text bg-gradient-to-br from-sky-400 to-indigo-500"></i>
                </div>
                <h2 class="text-3xl font-black text-white tracking-tight mb-2">
                    <%= fundName %>
                </h2>
                <p class="text-slate-400 text-sm font-medium tracking-wide uppercase">Command Center</p>
            </div>

            <% if(error) { %>
                <div
                    class="bg-rose-500/10 border border-rose-500/30 text-rose-400 px-5 py-4 rounded-2xl mb-8 flex items-start gap-4 text-sm animate-shake shadow-lg shadow-rose-500/5">
                    <i class="fas fa-exclamation-circle mt-0.5 text-base"></i>
                    <p class="font-medium leading-relaxed">
                        <%= error %>
                    </p>
                </div>
                <% } %>

                    <form action="/login" method="POST" class="space-y-6">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="space-y-2">
                            <label
                                class="block text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] ml-1">Identity</label>
                            <div class="relative group/input">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-5 pointer-events-none">
                                    <i
                                        class="fas fa-at text-slate-500 group-focus-within/input:text-sky-400 transition-colors duration-300"></i>
                                </div>
                                <input type="text" name="username" required autofocus placeholder="Enter your username"
                                    class="w-full pl-12 pr-5 py-4 bg-slate-800/50 border border-slate-700/50 rounded-2xl focus:outline-none focus:border-sky-500/50 focus:bg-slate-800/80 focus:ring-4 focus:ring-sky-500/10 text-white placeholder-slate-500 transition-all font-medium shadow-inner">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label
                                class="block text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] ml-1">Passkey</label>
                            <div class="relative group/input">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-5 pointer-events-none">
                                    <i
                                        class="fas fa-lock text-slate-500 group-focus-within/input:text-sky-400 transition-colors duration-300"></i>
                                </div>
                                <input type="password" name="password" required placeholder="••••••••"
                                    class="w-full pl-12 pr-5 py-4 bg-slate-800/50 border border-slate-700/50 rounded-2xl focus:outline-none focus:border-sky-500/50 focus:bg-slate-800/80 focus:ring-4 focus:ring-sky-500/10 text-white placeholder-slate-500 transition-all font-mono tracking-widest shadow-inner">
                            </div>
                        </div>

                        <div class="pt-4">
                            <button type="submit"
                                class="w-full py-4 bg-gradient-to-r from-sky-500 to-indigo-600 hover:from-sky-400 hover:to-indigo-500 text-white rounded-2xl font-black uppercase tracking-widest text-[11px] shadow-lg shadow-sky-500/25 hover:shadow-sky-500/40 focus:outline-none focus:ring-4 focus:ring-sky-500/30 transition-all flex justify-center items-center gap-3 relative overflow-hidden group/btn">
                                <span class="relative z-10">Authenticate</span>
                                <i
                                    class="fas fa-arrow-right relative z-10 opacity-70 group-hover/btn:opacity-100 group-hover/btn:translate-x-1 transition-all"></i>
                                <!-- Hover sheen effect -->
                                <div
                                    class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent group-hover/btn:animate-[shimmer_1.5s_infinite]">
                                </div>
                            </button>
                        </div>
                    </form>

                    <!-- Role info -->
                    <div class="mt-8 pt-6 border-t border-slate-700/50">
                        <div class="flex items-center justify-between px-2">
                            <div class="flex items-center gap-2 group/tip cursor-help">
                                <div
                                    class="w-6 h-6 rounded-full bg-sky-500/10 border border-sky-500/20 flex items-center justify-center text-sky-400 group-hover/tip:bg-sky-500 group-hover/tip:text-white transition-colors">
                                    <i class="fas fa-shield-alt text-[10px]"></i>
                                </div>
                                <span
                                    class="text-xs font-medium text-slate-400 group-hover/tip:text-slate-300 transition-colors">Secure
                                    Area</span>
                            </div>
                            <div class="text-[10px] font-bold text-slate-500 tracking-wider">
                                v1.2.5 (CI/CD Active)
                            </div>
                        </div>
                    </div>

                    <style>
                        @keyframes shimmer {
                            100% {
                                transform: translateX(100%);
                            }
                        }
                    </style>
        </div>
    </div>
</body>

</html>