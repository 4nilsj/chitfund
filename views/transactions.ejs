<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
        <title>Transactions - Chit Fund</title>
</head>

<body
    class="bg-background dark:bg-slate-900 font-sans antialiased text-slate-800 dark:text-slate-200 transition-colors duration-200">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <%- include('partials/sidebar') %>

            <main class="main-content relative flex flex-col flex-1 overflow-y-auto overflow-x-hidden md:ml-64 p-8">
                <header class="flex justify-between items-center mb-8">
                    <div>
                        <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Transactions</h1>
                        <p class="text-slate-500 dark:text-slate-400 mt-1">History of all financial movements</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="relative">
                            <i
                                class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
                            <input type="text" id="table-search" placeholder="Search transactions..."
                                class="pl-10 pr-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 dark:text-white dark:placeholder-slate-400 rounded-lg text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all w-64">
                        </div>
                        <% if (locals.user && locals.user.role !=='member' ) { %>
                            <button class="btn-primary"
                                onclick="document.getElementById('addTransactionModal').classList.remove('hidden')">
                                <i class="fas fa-plus"></i> Record New
                            </button>
                            <button class="btn-primary bg-indigo-600 hover:bg-indigo-700"
                                onclick="document.getElementById('bulk-txn-modal').classList.remove('hidden')">
                                <i class="fas fa-users"></i> Bulk
                            </button>
                            <% } %>
                                <a href="/export" class="btn-secondary">
                                    <i class="fas fa-download"></i> Export
                                </a>
                    </div>
                </header>

                <!-- Error/Success Messages -->
                <% if (typeof error !=='undefined' && error) { %>
                    <% if (error==='duplicate_contribution' ) { %>
                        <div
                            class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg relative flex items-center gap-3">
                            <i class="fas fa-exclamation-triangle"></i>
                            <div>
                                <strong class="font-bold">Duplicate payment!</strong>
                                <span class="block sm:inline">This member has already made a contribution for <%= typeof
                                        month !=='undefined' ? month : 'this month' %>.</span>
                            </div>
                        </div>
                        <% } else if (error==='duplicate_repayment' ) { %>
                            <div
                                class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg relative flex items-center gap-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <div>
                                    <strong class="font-bold">Duplicate payment!</strong>
                                    <span class="block sm:inline">This member has already made a repayment for <%=
                                            typeof month !=='undefined' ? month : 'this month' %>.</span>
                                </div>
                            </div>
                            <% } %>
                                <% } %>
                                    <% if (typeof msg !=='undefined' && msg) { %>
                                        <div class="alert alert-success">
                                            <i class="fas fa-check-circle"></i>
                                            <%= msg %>
                                        </div>
                                        <% } %>

                                            <div class="content-area">
                                                <div id="data-table-container"
                                                    class="card bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 overflow-hidden relative">

                                                    <!-- The table and pagination partial will be loaded here -->
                                                    <div class="table-wrapper">
                                                        <%- include('partials/transaction_table') %>
                                                    </div>

                                                </div>
                                            </div>
            </main>
    </div>

    <script src="/js/datatable.js"></script>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal"
        class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div
            class="modal max-w-sm bg-white dark:bg-slate-800 rounded-2xl shadow-2xl overflow-hidden transform transition-all border border-slate-200 dark:border-slate-700">
            <div class="p-8">
                <div
                    class="flex items-center justify-center w-16 h-16 mx-auto bg-rose-100 dark:bg-rose-900/30 rounded-full mb-6 text-rose-600 dark:text-rose-400">
                    <i class="fas fa-trash-alt text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white text-center mb-2">Delete Transaction</h3>
                <p class="text-slate-500 text-center mb-8 text-sm leading-relaxed">
                    Are you sure you want to remove this record? This action <span
                        class="text-rose-600 font-bold underline decoration-2">cannot be undone</span> and will affect
                    balance calculations.
                </p>

                <form id="delete-form" method="POST" class="flex flex-col gap-3">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit"
                        class="btn-primary bg-rose-600 hover:bg-rose-700 border-none w-full py-4 font-bold uppercase tracking-[0.2em] shadow-lg shadow-rose-100 order-2">
                        Confirm Deletion
                    </button>
                    <button type="button"
                        class="btn-secondary w-full py-3.5 font-bold uppercase tracking-widest text-slate-400 text-[10px] order-1"
                        onclick="document.getElementById('delete-modal').classList.add('hidden')">
                        Go Back
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Transaction Modal -->
    <div id="addTransactionModal"
        class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div
            class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden animate-reveal">
            <div
                class="bg-gradient-to-r from-primary to-primary-light px-8 py-6 flex justify-between items-center text-white">
                <div>
                    <h3 class="text-xl font-bold flex items-center gap-3">
                        <i class="fas fa-receipt"></i> System Entry
                    </h3>
                    <p class="text-white/70 text-xs mt-1">Logged entry for fund movement</p>
                </div>
                <button onclick="document.getElementById('addTransactionModal').classList.add('hidden')"
                    class="text-white/60 hover:text-white transition-colors">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>

            <form action="/transactions/add" method="POST" class="p-8 space-y-6">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Entry Date</label>
                        <input type="date" name="date" required value="<%= new Date().toISOString().split('T')[0] %>"
                            class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium text-sm">
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Transaction
                            Type</label>
                        <div class="relative">
                            <select name="type" required
                                class="w-full pl-4 pr-10 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium text-sm appearance-none cursor-pointer">
                                <option value="contribution">Contribution</option>
                                <option value="disbursement">Disbursement</option>
                                <option value="repayment">Loan Repayment</option>
                                <option value="expense">Expense</option>
                                <option value="penalty">Penalty</option>
                            </select>
                            <i
                                class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-xs"></i>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Associated
                        Person</label>
                    <div class="relative group">
                        <i
                            class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors"></i>
                        <select name="person_id"
                            class="w-full pl-11 pr-10 py-3.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium appearance-none cursor-pointer">
                            <option value="">-- System Transaction --</option>
                            <% if(locals.members) { %>
                                <% members.forEach(m=> { %>
                                    <option value="<%= m.id %>">
                                        <%= m.name %> (<%= m.type %>)
                                    </option>
                                    <% }); %>
                                        <% } %>
                        </select>
                        <i
                            class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-xs"></i>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Amount (₹)</label>
                    <div class="relative group">
                        <span
                            class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold group-focus-within:text-primary transition-colors text-xl">₹</span>
                        <input type="number" name="amount" required min="0" step="1" placeholder="0"
                            class="w-full pl-10 pr-4 py-4 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-mono text-2xl font-bold text-slate-800">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Description /
                        Remarks</label>
                    <div class="relative group">
                        <i
                            class="fas fa-pencil-alt absolute left-4 top-4 text-slate-400 group-focus-within:text-primary transition-colors"></i>
                        <textarea name="remarks" placeholder="Optional context for this ledger entry..." rows="2"
                            class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium text-sm"></textarea>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-6 border-t border-slate-100">
                    <button type="button" class="btn-secondary px-6 py-3 font-bold text-sm uppercase tracking-wider"
                        onclick="document.getElementById('addTransactionModal').classList.add('hidden')">Discard</button>
                    <button type="submit"
                        class="btn-primary px-8 py-3 font-bold text-sm uppercase tracking-wider shadow-lg shadow-primary/20">
                        Commit Entry
                    </button>
                </div>
            </form>
        </div>
    </div>


    <!-- Bulk Contribution Modal -->
    <div id="bulk-txn-modal"
        class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div
            class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden animate-reveal flex flex-col max-h-[90vh]">
            <div
                class="bg-gradient-to-r from-primary to-primary-dark px-8 py-6 flex justify-between items-center text-white shrink-0">
                <div>
                    <h3 class="text-xl font-bold flex items-center gap-3">
                        <i class="fas fa-layer-group"></i> Batch Deposits
                    </h3>
                    <p class="text-white/70 text-xs mt-1">Multi-member monthly contribution entry</p>
                </div>
                <button onclick="document.getElementById('bulk-txn-modal').classList.add('hidden')"
                    class="text-white/60 hover:text-white transition-colors">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>

            <form action="/transactions/bulk-add" method="POST"
                class="flex-1 overflow-y-auto p-8 space-y-6 custom-scrollbar">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Collection
                            Date</label>
                        <div class="relative">
                            <i class="fas fa-calendar absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                            <input type="date" name="date" required
                                value="<%= new Date().toISOString().split('T')[0] %>"
                                class="w-full pl-11 pr-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium text-sm">
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Daily/Monthly
                            Amount (₹)</label>
                        <div class="relative group">
                            <span
                                class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold group-focus-within:text-primary transition-colors text-lg">₹</span>
                            <input type="number" name="amount" required min="0" step="1" placeholder="0"
                                class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-mono font-bold text-slate-800 text-lg">
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex justify-between items-center px-1">
                        <div class="flex flex-col">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-wider">Select
                                Contributors</label>
                            <p class="text-[10px] text-slate-400 mt-0.5">Choose members participating in this batch</p>
                        </div>
                        <div class="flex items-center gap-3 p-2 bg-slate-50 rounded-lg border border-slate-200">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="select-all-members" onchange="toggleAllMembers(this)"
                                    class="sr-only peer">
                                <div
                                    class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary">
                                </div>
                                <span
                                    class="ml-2 text-[10px] font-black text-slate-500 uppercase tracking-widest select-none">All</span>
                            </label>
                        </div>
                    </div>

                    <div
                        class="border border-slate-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-900/50 p-4 max-h-[220px] overflow-y-auto custom-scrollbar shadow-inner">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <% if(locals.members) { %>
                                <% members.forEach(m=> { %>
                                    <label
                                        class="group flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 cursor-pointer transition-all border border-slate-100 dark:border-slate-700 hover:border-primary/20 shadow-sm bg-white dark:bg-slate-800 dark:text-white">
                                        <div class="relative flex items-center">
                                            <input type="checkbox" name="member_ids" value="<%= m.id %>"
                                                id="member_<%= m.id %>"
                                                class="member-checkbox w-5 h-5 rounded-lg border-slate-200 text-primary focus:ring-primary transition-all">
                                        </div>
                                        <div class="flex flex-col">
                                            <span
                                                class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover:text-primary transition-colors">
                                                <%= m.name %>
                                            </span>
                                            <span class="text-[10px] text-slate-400 capitalize">
                                                <%= m.type %>
                                            </span>
                                        </div>
                                    </label>
                                    <% }); %>
                                        <% } %>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider ml-1">Batch Context</label>
                    <input type="text" name="remarks"
                        placeholder="e.g. Monthly Collection Period - <%= new Date().toLocaleString('default', { month: 'long' }) %>"
                        class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 dark:text-white rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all font-medium text-sm">
                </div>

                <div class="flex justify-end gap-3 pt-6 border-t border-slate-100 shrink-0">
                    <button type="button"
                        class="btn-secondary px-6 py-3 font-bold text-sm uppercase tracking-widest transition-all"
                        onclick="document.getElementById('bulk-txn-modal').classList.add('hidden')">Cancel</button>
                    <button type="submit"
                        class="btn-primary px-10 py-3 font-bold text-sm uppercase tracking-widest shadow-xl shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-0.5 transition-all">
                        <i class="fas fa-play-circle mr-2"></i> Process Batch
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script>
        // Use generic search
        document.addEventListener('DOMContentLoaded', setupSearch);

        function openDeleteModal(id) {
            const form = document.getElementById('delete-form');
            form.action = `/transactions/delete/${id}`;
            document.getElementById('delete-modal').classList.remove('hidden');
        }

        function toggleAllMembers(source) {
            const checkboxes = document.getElementsByClassName('member-checkbox');
            for (let i = 0; i < checkboxes.length; i++) {
                checkboxes[i].checked = source.checked;
            }
        }

        // Toggle required attribute on member select based on transaction type
        document.addEventListener('DOMContentLoaded', () => {
            const typeSelect = document.querySelector('select[name="type"]');
            const personSelect = document.querySelector('select[name="person_id"]');

            if (typeSelect && personSelect) {
                const updateRequired = () => {
                    const type = typeSelect.value;
                    if (['contribution', 'disbursement', 'repayment'].includes(type)) {
                        personSelect.required = true;
                    } else {
                        personSelect.required = false;
                    }
                };

                typeSelect.addEventListener('change', updateRequired);
                updateRequired(); // Initial check
            }
        });
    </script>
</body>

</html>