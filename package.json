{
  "name": "chitfund",
  "version": "1.0.0",
  "description": "Chit Fund Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch",
    "test": "jest --runInBand --coverage --testPathIgnorePatterns=tests/e2e",
    "test:e2e": "jest tests/e2e",
    "test:watch": "jest --watch",
    "test:verbose": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "utils/**/*.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 40,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "keywords": [
    "chit",
    "fund",
    "management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "chart.js": "^4.5.1",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "csurf": "^1.11.0",
    "ejs": "^4.0.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "puppeteer": "^24.36.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17"
  }
}
